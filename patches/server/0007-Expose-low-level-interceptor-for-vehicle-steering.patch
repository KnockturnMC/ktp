-    private Vec3 collide(Vec3 movement) {
+    // ktp start - expose to static environment
+    public Vec3 collide(Vec3 movement) {
+        return collideStatic(movement, this.level, this.getBoundingBox(), this);
+    }
+    public static Vec3 collideStatic(Vec3 movement, Level level, AABB boundingBox, @javax.annotation.Nullable Entity entity) {
+        // ktp end - expose to static environment
         // Paper start - optimise collisions
         final boolean xZero = movement.x == 0.0;
         final boolean yZero = movement.y == 0.0;
@@ -1475,8 +1479,8 @@ public abstract class Entity implements Nameable, EntityAccess, CommandSource, S
             return movement;
         }
 
-        final Level world = this.level;
-        final AABB currBoundingBox = this.getBoundingBox();
+        final Level world = level; // ktp - expose to static environment
+        final AABB currBoundingBox = boundingBox; // ktp - expose to static environment
 
         if (io.papermc.paper.util.CollisionUtil.isEmpty(currBoundingBox)) {
             return movement;
@@ -1484,9 +1488,9 @@ public abstract class Entity implements Nameable, EntityAccess, CommandSource, S
 
         final List<AABB> potentialCollisionsBB = new java.util.ArrayList<>();
         final List<VoxelShape> potentialCollisionsVoxel = new java.util.ArrayList<>();
-        final double stepHeight = (double)this.maxUpStep();
+        final double stepHeight = entity != null ? (double)entity.maxUpStep() : 0; // ktp - expose to static environment
         final AABB collisionBox;
-        final boolean onGround = this.onGround;
+        final boolean onGround = entity != null ? entity.onGround : false; // ktp - expose to static environment
 
         if (xZero & zZero) {
             if (movement.y > 0.0) {
@@ -1509,7 +1513,7 @@ public abstract class Entity implements Nameable, EntityAccess, CommandSource, S
         }
 
         io.papermc.paper.util.CollisionUtil.getCollisions(
-                world, this, collisionBox, potentialCollisionsVoxel, potentialCollisionsBB,
+                world, entity, collisionBox, potentialCollisionsVoxel, potentialCollisionsBB, // ktp - expose to static environment
                 io.papermc.paper.util.CollisionUtil.COLLISION_FLAG_CHECK_BORDER,
                 null, null
         );
diff --git a/src/main/java/org/bukkit/craftbukkit/CraftWorld.java b/src/main/java/org/bukkit/craftbukkit/CraftWorld.java
index bfb178c69026e9759e9afaebb9da141b62d1f144..b47988e0dc0a39342233a0bd61fef92011d6a9a0 100644
--- a/src/main/java/org/bukkit/craftbukkit/CraftWorld.java
+++ b/src/main/java/org/bukkit/craftbukkit/CraftWorld.java
@@ -2525,4 +2525,21 @@ public class CraftWorld extends CraftRegionAccessor implements World {
         return this.adventure$pointers;
     }
     // Paper end
+    // KTP start - expose low level steering interceptors
+    @Override
+    public @NotNull Vector computeCollisionCorrectedMovementFor(@NotNull Vector movement, @NotNull BoundingBox boundingBox) {
+        return io.papermc.paper.util.MCUtil.toVector(
+            net.minecraft.world.entity.Entity.collideStatic(
+                io.papermc.paper.util.MCUtil.toVec3(movement),
+                this.getHandle(),
+                new net.minecraft.world.phys.AABB(
+                    boundingBox.getMinX(), boundingBox.getMinY(), boundingBox.getMinZ(),
+                    boundingBox.getMaxX(), boundingBox.getMaxY(), boundingBox.getMaxZ()
+                ),
+                null
+            )
+        );
+    }
+    // KTP stop - expose low level steering interceptors
+
 }
diff --git a/src/main/java/org/bukkit/craftbukkit/entity/CraftEntity.java b/src/main/java/org/bukkit/craftbukkit/entity/CraftEntity.java
index baf03ed7755115f30f3eb303e5a70b1b8c05017e..e1a3ae04a4c77d56053b137fc21eff8cacc00dc9 100644
--- a/src/main/java/org/bukkit/craftbukkit/entity/CraftEntity.java
+++ b/src/main/java/org/bukkit/craftbukkit/entity/CraftEntity.java
@@ -1255,4 +1255,37 @@ public abstract class CraftEntity implements org.bukkit.entity.Entity {
         return this.getHandle().getScoreboardName();
     }
     // Paper end - entity scoreboard name
+    // KTP start
+
+    @Override
+    public void move(@org.jetbrains.annotations.NotNull final dev.lynxplay.ktp.entity.MovementCause movementCause,
+                     @org.jetbrains.annotations.NotNull final Vector vector) {
+        final var internalMovementCause = switch (movementCause) {
+            case SELF -> net.minecraft.world.entity.MoverType.SELF;
+            case PLAYER -> net.minecraft.world.entity.MoverType.PLAYER;
+            case PISTON -> net.minecraft.world.entity.MoverType.PISTON;
+            case SHULKER -> net.minecraft.world.entity.MoverType.SHULKER;
+            case SHULKER_BOX -> net.minecraft.world.entity.MoverType.SHULKER_BOX;
+        };
+        this.entity.move(internalMovementCause, io.papermc.paper.util.MCUtil.toVec3(vector));
+    }
+
+    @Override
+    public void physics(final boolean physics) {
+        this.entity.noPhysics = !physics;
+    }
+
+    @Override
+    public boolean physics() {
+        return !this.entity.noPhysics;
+    }
+
+    @Override
+    @org.jetbrains.annotations.NotNull
+    public Vector correctMovementForCollision(@org.jetbrains.annotations.NotNull Vector movement) {
+        return io.papermc.paper.util.MCUtil.toVector(
+            this.entity.collide(io.papermc.paper.util.MCUtil.toVec3(movement))
+        );
+    }
+    // KTP end
 }
