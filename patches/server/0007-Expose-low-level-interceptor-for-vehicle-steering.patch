-    private Vec3 collide(Vec3 movement) {
+    // ktp start - expose to static environment
+    public Vec3 collide(Vec3 movement) {
+        return collideStatic(movement, this.level, this.getBoundingBox(), this);
+    }
+    public static Vec3 collideStatic(Vec3 movement, Level level, AABB boundingBox, @javax.annotation.Nullable Entity entity) {
+        // ktp end - expose to static environment
         // Paper start - optimise collisions
         final boolean xZero = movement.x == 0.0;
         final boolean yZero = movement.y == 0.0;
@@ -1517,8 +1521,8 @@ public abstract class Entity implements SyncedDataHolder, Nameable, EntityAccess
             return movement;
         }
 
-        final Level world = this.level;
-        final AABB currBoundingBox = this.getBoundingBox();
+        final Level world = level; // ktp - expose to static environment
+        final AABB currBoundingBox = boundingBox; // ktp - expose to static environment
 
         if (io.papermc.paper.util.CollisionUtil.isEmpty(currBoundingBox)) {
             return movement;
@@ -1526,9 +1530,9 @@ public abstract class Entity implements SyncedDataHolder, Nameable, EntityAccess
 
         final List<AABB> potentialCollisionsBB = new java.util.ArrayList<>();
         final List<VoxelShape> potentialCollisionsVoxel = new java.util.ArrayList<>();
-        final double stepHeight = (double)this.maxUpStep();
+        final double stepHeight = entity != null ? (double)entity.maxUpStep() : 0; // ktp - expose to static environment
         final AABB collisionBox;
-        final boolean onGround = this.onGround;
+        final boolean onGround = entity != null ? entity.onGround : false; // ktp - expose to static environment
 
         if (xZero & zZero) {
             if (movement.y > 0.0) {
@@ -1551,7 +1555,7 @@ public abstract class Entity implements SyncedDataHolder, Nameable, EntityAccess
         }
 
