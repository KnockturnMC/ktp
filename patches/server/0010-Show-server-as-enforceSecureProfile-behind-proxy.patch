From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Bjarne Koll <lynxplay101@gmail.com>
Date: Mon, 13 Feb 2023 23:40:25 +0100
Subject: [PATCH] Show server as enforceSecureProfile behind proxy

When a server is behind a proxy server, its online-mode setting locally
is set to false as authentication is left to the proxy server.
While modern forwarding under velocity allows for an online-moder
server, bungee does not.

To prevent the popup under a bungee system that requires a full
system-message chat setup, this patch defines a server as
enforceSecureProfile if it is configured to be in a proxy-online mode.

diff --git a/src/main/java/net/minecraft/server/dedicated/DedicatedServer.java b/src/main/java/net/minecraft/server/dedicated/DedicatedServer.java
index dbccbcb9b44e4efacdf53c2d161115cc20b36cff..2169dc86e834b138604a681eb582c456fa1ab676 100644
--- a/src/main/java/net/minecraft/server/dedicated/DedicatedServer.java
+++ b/src/main/java/net/minecraft/server/dedicated/DedicatedServer.java
@@ -638,7 +638,7 @@ public class DedicatedServer extends MinecraftServer implements ServerInterface
     public boolean enforceSecureProfile() {
         DedicatedServerProperties dedicatedserverproperties = this.getProperties();
 
-        return dedicatedserverproperties.enforceSecureProfile && dedicatedserverproperties.onlineMode && this.services.profileKeySignatureValidator() != null;
+        return dedicatedserverproperties.enforceSecureProfile && io.papermc.paper.configuration.GlobalConfiguration.get().proxies.isProxyOnlineMode() &&  this.services.profileKeySignatureValidator() != null; // KTP - properly support secure profile verification when in proxy online mode
     }
 
     @Override
